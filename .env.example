# Protegrity Developer Edition Trial Center - Environment Configuration
#
# IMPORTANT: Copy this file to .env and fill in your actual values.
# `.env` is git-ignored and never committed.
#
# This is a Developer-Edition product intended for local exploration. Storing
# credentials in a local `.env` is acceptable for that use case. Do NOT reuse
# this pattern for real production deployments.

# ============================================================================
# PROTEGRITY DEVELOPER EDITION CREDENTIALS  (REQUIRED)
# ============================================================================
# Obtain these from: https://www.protegrity.com/developer-edition

DEV_EDITION_EMAIL=your-email@example.com
DEV_EDITION_PASSWORD=your-password-here
DEV_EDITION_API_KEY=your-api-key-here

# ============================================================================
# BACKEND SERVICE URLS  (OPTIONAL — override only if non-default)
# ============================================================================
# The Trial Center expects the Protegrity backend services to ALREADY be
# running on this host (see docs/GETTING_STARTED.md -> Prerequisites).
#
# By default the containerised UI reaches them at:
#   http://host.docker.internal:8581   (Semantic Guardrail)
#   http://host.docker.internal:8580   (Classification / Data Discovery)
#
# Override below if your backends are on a different host or port.
# SEMANTIC_GUARDRAIL_URL=http://host.docker.internal:8581
# CLASSIFICATION_SERVICE_URL=http://host.docker.internal:8580

# ============================================================================
# APPLICATION SETTINGS  (OPTIONAL)
# ============================================================================

# Trial Center UI port on the host (default: 8502)
TRIAL_CENTER_PORT=8502

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Trial Center image tag built by `docker compose build` (semver)
TRIAL_CENTER_VERSION=1.1.0
